# Firebase Web SDK config — copy this file to `.env` and fill in real values.
# Values come from: Firebase Console -> Project settings -> General -> Your apps -> SDK setup and configuration -> Config.
# DO NOT commit the real `.env` file. `.gitignore` already excludes it.

# Expo requires the EXPO_PUBLIC_ prefix for vars that should be readable in the
# client bundle (process.env.EXPO_PUBLIC_FIREBASE_API_KEY, etc.). These keys are
# safe to ship to the client — Firestore is secured by Security Rules, not by
# hiding the API key.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
